# Database
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=pg_management
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Database Connection Pool (optional tuning)
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=5
DATABASE_POOL_ACQUIRE_TIMEOUT=30000
DATABASE_POOL_IDLE_TIMEOUT=10000
# DATABASE_CA_CERT= (only required for production SSL connections)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REQUIRED in production. Generate a strong random password.
REDIS_PASSWORD=your_redis_password_change_in_production

# JWT
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Super Admin (comma-separated emails)
SUPER_ADMIN_EMAILS=admin@pgmanager.com

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# S3 Storage (MinIO compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pg-management
S3_REGION=us-east-1

# Resend (for sending emails)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# SMS Provider (MSG91)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=PGMGR
MSG91_TEMPLATE_ID=your_template_id

# Twilio (alternative SMS provider)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Sentry (error tracking - optional)
SENTRY_DSN=

# Metrics token (REQUIRED in production - protects /metrics endpoint)
METRICS_TOKEN=your_metrics_token_change_in_production

# MFA encryption key (REQUIRED in production - 32+ chars for AES-256)
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_min_32_chars_change_in_production

# Environment
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# OTP (Optional - if phone verification is added later)
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# Invoice Generation
INVOICE_JOB_CRON=0 0 * * *
INVOICE_DUE_DAYS=5

# Logging
LOG_LEVEL=debug