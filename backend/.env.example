# ============================================
# PG Management Backend Environment Variables
# Copy this file to .env and fill in real values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
# The backend connects to the DB container started by Docker Compose (root .env)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=pg_management

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT (generate strong random strings, min 32 chars) ---
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- Super Admin (comma-separated emails) ---
SUPER_ADMIN_EMAILS=admin@pgmanager.com

# --- Razorpay ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Email (Resend) ---
# Get your API key from https://resend.com/api-keys
# Leave empty in dev mode to log emails to DB only
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# --- File Upload (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=pg-management

# --- Database Connection Pool ---
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=5
DATABASE_POOL_ACQUIRE_TIMEOUT=30000
DATABASE_POOL_IDLE_TIMEOUT=10000

# --- Monitoring ---
# Optional: token required to access /metrics endpoint
# METRICS_TOKEN=your-secret-metrics-token

# --- Logging ---
LOG_LEVEL=debug

# --- Optional: Production Database SSL ---
# DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----\n...
